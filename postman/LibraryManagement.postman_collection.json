{
  "info": {
    "name": "Library Management System API",
    "description": "Complete API collection for the Library Management System.\n\n## Authentication\nMost endpoints require a Bearer token. Use the Login request to authenticate, then set the `token` variable.\n\n## Default Credentials\n- admin / Password123 (Administrator)\n- librarian1 / Password123 (Librarian)\n- staff1 / Password123 (Staff)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5204"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);",
                  "pm.collectionVariables.set('refreshToken', jsonData.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Revoke Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/revoke",
              "path": ["api", "auth", "revoke"]
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "Get Book by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/1",
              "path": ["api", "books", "1"]
            }
          }
        },
        {
          "name": "Search Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/search?title=Foundation&author=Asimov&category=Science%20Fiction",
              "path": ["api", "books", "search"],
              "query": [
                { "key": "title", "value": "Foundation" },
                { "key": "author", "value": "Asimov" },
                { "key": "category", "value": "Science Fiction" }
              ]
            }
          }
        },
        {
          "name": "Get Books by Status (In)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/status/In",
              "path": ["api", "books", "status", "In"]
            }
          }
        },
        {
          "name": "Get Books by Status (Out)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/status/Out",
              "path": ["api", "books", "status", "Out"]
            }
          }
        },
        {
          "name": "Create Book (Admin/Librarian)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isbn\": \"978-1234567890\",\n  \"title\": \"New Book Title\",\n  \"edition\": \"1st\",\n  \"publicationYear\": 2026,\n  \"summary\": \"A brand new book\",\n  \"pageCount\": 350,\n  \"language\": \"English\",\n  \"publisherId\": 1,\n  \"authorIds\": [1, 2],\n  \"categoryIds\": [1, 5]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "Update Book (Admin/Librarian)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Book Title\",\n  \"summary\": \"Updated summary\",\n  \"status\": \"In\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books/1",
              "path": ["api", "books", "1"]
            }
          }
        },
        {
          "name": "Delete Book (Admin only)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/books/1",
              "path": ["api", "books", "1"]
            }
          }
        }
      ]
    },
